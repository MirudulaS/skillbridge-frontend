model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String
  createdAt DateTime  @default(now())

  progresses Progress[]
}

model Progress {
  id         Int      @id @default(autoincrement())
  module     String
  submodule  String
  taskNumber Int
  completed  Boolean @default(true)

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, module, submodule, taskNumber])
}
